# ============================================
# SEO Content Generator - 環境変数設定
# ============================================
# このファイルをコピーして .env として保存し、
# 各値を実際の設定に書き換えてください。
#
# NOTE:
# - VITE_ で始まる環境変数はフロントエンド（ブラウザ）に埋め込まれます。
# - 公開デプロイする場合は、APIキー/パスワード/Webhook等の秘匿値を VITE_ に入れないでください。

# ============================================
# 必須設定
# ============================================

# Gemini API Key（Google AI Studio で取得）
GEMINI_API_KEY=your_gemini_api_key_here
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 競合調査用 検索API（どちらか一方を設定）
#
# 【推奨】Google Custom Search API
#   取得先: https://console.cloud.google.com/ （Custom Search API を有効化）
#   検索エンジンID: https://programmablesearchengine.google.com/ で作成
GOOGLE_API_KEY=your_google_api_key_here
VITE_GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
VITE_GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here
#
# 【代替】Serper API（Custom Search API が使えない場合）
#   新規GCPプロジェクトでCustom Search APIを有効化できない場合はこちらを使用
#   取得先: https://serper.dev （登録で2,500クレジット無料）
#   設定する場合は上のGOOGLE_API_KEY等は不要です（SERPER_API_KEYが優先されます）
# SERPER_API_KEY=your_serper_api_key_here

# スプレッドシートモード用（Google SheetsのID）
SPREADSHEET_ID=your_spreadsheet_id_here

# ============================================
# サービス設定（自社ブランド）
# ============================================

# 自社サービス名（記事内で使用）
VITE_SERVICE_NAME=当社サービス

# 自社会社名（ファクトチェックで使用）
VITE_COMPANY_NAME=当社

# ============================================
# 自社一次情報URL設定（出典優先順位に使用）
# ============================================
# 設定すると、これらのURLが出典として優先的に採用されます
# 未設定の場合は汎用的な動作になります

# 自社noteアカウントURL（例：note.com/yourcompany）
# VITE_COMPANY_NOTE_URL=note.com/yourcompany

# 自社メディアサイトURL（例：media.yourcompany.com）
# VITE_COMPANY_MEDIA_URL=media.yourcompany.com

# 自社コーポレートサイトURL（例：yourcompany.com）
# VITE_COMPANY_SITE_URL=yourcompany.com

# ============================================
# オプション設定
# ============================================

# OpenAI API Key（GPT-5 最終校閲用）
OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_ORG_ID=your_openai_org_id_here

# 内部API認証用キー（任意の文字列）
INTERNAL_API_KEY=your_internal_api_key_here
VITE_INTERNAL_API_KEY=your_internal_api_key_here

# バックエンドURL設定
VITE_API_URL=http://localhost:3001/api
VITE_BACKEND_URL=http://localhost:3001

# ============================================
# Notionブログ連携設定（画像生成・記事保存用）
# ============================================

# Notion Integrationのシークレット（VITE_ を付けない）
NOTION_API_KEY=ntn_your_notion_integration_secret

# ブログ記事データベースのデータソースID
NOTION_BLOG_DATA_SOURCE_ID=your_notion_data_source_id

# 保存時の既定値
NOTION_BLOG_DEFAULT_STATUS=draft
NOTION_BLOG_DEFAULT_AUTHOR=勅使河原　将
NOTION_BLOG_DEFAULT_SHOP_SLUG=corporate

# ============================================
# Slack通知設定（オプション）
# ============================================

# Slack Webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ============================================
# Google Drive連携設定（オプション）
# ============================================

# Google DriveフォルダID（実績データ用）
# COMPANY_DATA_FOLDER_ID=your_google_drive_folder_id

# ============================================
# 画像生成設定（オプション）
# ============================================

# 画像生成サービスURL
VITE_IMAGE_GEN_URL=http://localhost:5177

# メインアプリURL
VITE_MAIN_APP_URL=http://localhost:5176

# GoogleサービスアカウントJSONキー
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project",...}
